rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Categories
    match /categories/{categoryId} {
      allow read: if true; // Publicly readable
      allow create: if isAdmin() && isValidId(categoryId);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Dresses
    match /dresses/{dressId} {
      allow read: if true; // Publicly readable
      allow create: if isAdmin() && isValidId(dressId);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    
    // Admin collection (to bootsttrap)
    match /admins/{adminId} {
      allow read: if isSignedIn() && request.auth.uid == adminId;
      allow write: if false; // Only manageable via Firebase Console or manual entry
    }
  }
}
